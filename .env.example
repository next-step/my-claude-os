# JWT 서명에 사용할 시크릿 키 (필수). 충분히 긴 무작위 값을 넣을 것.
# 예: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret

# JWT 만료 시간(분). 기본 60.
JWT_EXPIRE_MIN=60

# JWT 서명 알고리즘. 기본 HS256.
JWT_ALGORITHM=HS256

# DB 접속 URL. 기본 sqlite:///./app.db
DATABASE_URL=sqlite:///./app.db
