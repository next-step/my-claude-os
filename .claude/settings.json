{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/record-skill-usage.py\"",
            "statusMessage": "스킬 호출 기록 중..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-dev-server.sh\"",
            "statusMessage": "자동 기동한 dev 서버 정리 중..."
          }
        ]
      }
    ]
  }
}
